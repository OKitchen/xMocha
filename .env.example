# xMocha public deployment environment template.
# Copy these keys into your hosting platform environment settings.

# Server default provider only. The browser can still override provider/model
# per Decision Mode or World Mode request from Model settings.
XMOCHA_MODEL_PROVIDER=google
XMOCHA_TURN_SIMULATOR=legacy
XMOCHA_SOCIETY_SIMULATOR=template
GOOGLE_API_KEY=
GOOGLE_GENAI_MODEL=gemma-4-26b-a4b-it
GOOGLE_MAX_OUTPUT_TOKENS=4000
XMOCHA_GENERATION_TIMEOUT_MS=50000

# Recommended in production. Use a random value to make stored IP hashes
# resistant to offline guessing. Never expose it with a NEXT_PUBLIC_ prefix.
XMOCHA_RATE_LIMIT_SALT=

# Optional for offline/high-latency quality runs. Omit for the interactive MVP.
# GOOGLE_THINKING_LEVEL=HIGH

# Optional local proxy for environments where Google APIs require a system proxy.
# Do not configure these on Vercel unless the deployment environment requires it.
# NODE_USE_ENV_PROXY=1
# HTTP_PROXY=http://127.0.0.1:7897
# HTTPS_PROXY=http://127.0.0.1:7897
# ALL_PROXY=socks5://127.0.0.1:7897

# Local persistence is file-backed by default when DATABASE_URL is unset:
# .xmocha-data/sessions, .xmocha-data/world-packs, .xmocha-data/turn-runs.
# Durable production persistence is required on serverless hosting.
# XMOCHA_SESSION_STORAGE=postgres
# DATABASE_URL=

# Optional local Gemma/Ollama runtime.
GEMMA_RUNTIME=ollama
GEMMA_MODEL=gemma4
OLLAMA_BASE_URL=http://localhost:11434

# Optional Hugging Face Router model comparison.
# The homepage model picker can override provider/model per session without
# storing tokens in session state.
# HF_TOKEN=
# HUGGINGFACE_MODEL=zai-org/GLM-5.2:zai-org
# HUGGINGFACE_BASE_URL=https://router.huggingface.co/v1
# HUGGINGFACE_MAX_TOKENS=6000

# Optional OpenAI model comparison.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-5.4-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MAX_OUTPUT_TOKENS=6000

# Optional DeepSeek / Anthropic model comparison.
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
